# LLM provider
ANTHROPIC_API_KEY=

# TypeDB server. TYPEDB_ADDRESS is the driver's gRPC endpoint (:1729) used by the
# seed loader and the checkpoint/store. The MCP server reaches TypeDB over its HTTP
# port (:8000) instead — that's configured in docker-compose.yml, not here.
TYPEDB_ADDRESS=localhost:1729
TYPEDB_USERNAME=admin
TYPEDB_PASSWORD=password
TYPEDB_DATABASE=ticker

# TypeDB-backed LangGraph persistence (auto-created by the plugins on first run)
TYPEDB_CHECKPOINT_DB=langgraph_checkpoints
TYPEDB_STORE_DB=langgraph_memory

# TypeDB MCP server endpoint
TYPEDB_MCP_URL=http://localhost:8001/mcp

# Path to the typeql-check binary (built from typedb-console/typeql-check)
TYPEQL_CHECK_BIN=typeql-check
