  $san-francisco isa place, has id "plc-americas/northern-america/united-states/california/san-francisco";
insert
  $o1 isa company, has username "QuantumSynergySolutions", has name "Quantum Synergy Solutions", has bio "A leader in cutting-edge tech consulting, Quantum Synergy Solutions specializes in optimizing business operations through innovative technologies. Focused on delivering customized, efficient solutions for industries looking to thrive in the digital era. Pioneering advancements that drive growth and streamline processes.", has profile-picture "med-0e370526558243bd9476fe38babd4745", has is-active true, has is-visible true, has can-publish true, has tag "#TechConsulting", has tag "#BusinessSolutions", has tag "#Innovation", has tag "#DigitalTransformation", has tag "#ProcessOptimization", has tag "#TechAdvancement";
  (place: $los-angeles, located: $o1) isa location;

  $o2 isa company, has username "BlueWaveAnalytics", has name "BlueWave Analytics", has bio "At the forefront of data-driven insights, BlueWave Analytics empowers businesses to make smarter decisions with advanced analytics and machine learning. Our team helps companies transform raw data into actionable intelligence, driving innovation and efficiency across sectors.", has profile-picture "med-7de8a2342412479daaf944e07b38785b", has is-active true, has is-visible true, has can-publish true, has tag "#DataAnalytics", has tag "#MachineLearning", has tag "#BusinessInsights", has tag "#DataScience", has tag "#BigData", has tag "#PredictiveAnalytics";
  (place: $montreal, located: $o2) isa location;

  $o3 isa company, has username "ApexGlobalEnterprises", has name "Apex Global Enterprises", has bio "Apex Global Enterprises is a dynamic leader in international business development and strategy. We specialize in expanding brands into global markets, offering comprehensive solutions for growth and sustainability. Our mission is to help businesses reach their highest potential on the world stage.", has profile-picture "med-b2ddc481ac6d4df894e5064cb799ae8e", has is-active true, has is-visible true, has can-publish true, has tag "#GlobalBusiness", has tag "#InternationalGrowth", has tag "#BusinessStrategy", has tag "#MarketExpansion", has tag "#BusinessDevelopment", has tag "#GlobalMarkets";
  (place: $austin, located: $o3) isa location;

  $o4 isa company, has username "SilverLeafTechnologies", has name "SilverLeaf Technologies", has bio "SilverLeaf Technologies is an innovator in sustainable tech solutions, providing eco-friendly alternatives for modern businesses. Our goal is to create technology that not only enhances efficiency but also minimizes environmental impact. Bridging the gap between progress and sustainability.", has profile-picture "med-69407be75a4f4145bc98c279cf6f111c", has is-active true, has is-visible true, has can-publish true, has tag "#SustainableTech", has tag "#EcoFriendly", has tag "#GreenTechnology", has tag "#TechInnovation", has tag "#EnvironmentalSolutions", has tag "#CleanTech";
  (place: $los-angeles, located: $o4) isa location;

  $o5 isa company, has username "HorizonInnovationsGroup", has name "Horizon Innovations Group", has bio "Horizon Innovations Group is a forward-thinking firm dedicated to creating tomorrow's technologies today. We focus on research and development across multiple industries, fostering innovation and pushing boundaries in product design, AI, and emerging tech.", has profile-picture "med-7579501a62fd4854b75e0ec39c9d03f3", has is-active true, has is-visible true, has can-publish true, has tag "#ResearchAndDevelopment", has tag "#EmergingTech", has tag "#AI", has tag "#TechInnovation", has tag "#ProductDesign", has tag "#FutureTech", has tag "#CuttingEdge";
  (place: $los-angeles, located: $o5) isa location;

  $o6 isa company, has username "RedwoodDigitalLabs", has name "Redwood Digital Labs", has bio "Redwood Digital Labs is a creative powerhouse for web development and digital design. We bring brands to life with sleek, user-friendly websites and digital experiences that captivate audiences. Our team thrives on building solutions that merge creativity with technology.", has profile-picture "med-26c00984c7344b05b88c31f619faa06e", has is-active true, has is-visible true, has can-publish true, has tag "#WebDevelopment", has tag "#DigitalDesign", has tag "#CreativeTech", has tag "#UXDesign", has tag "#WebSolutions", has tag "#DigitalExperience", has tag "#GraphicDesign";
  (place: $sacramento, located: $o6) isa location;

  $o7 isa company, has username "StellarVisionMedia", has name "StellarVision Media", has bio "StellarVision Media is a full-service creative agency specializing in video production, digital marketing, and content strategy. We help brands tell their stories through stunning visuals and compelling narratives. Turning big ideas into powerful media experiences.", has profile-picture "med-21f8c1569e0d445b992a34a1084fa819", has is-active true, has is-visible true, has can-publish true, has tag "#MediaProduction", has tag "#VideoMarketing", has tag "#ContentStrategy", has tag "#DigitalMedia", has tag "#CreativeAgency", has tag "#VisualStorytelling";
  (place: $boston, located: $o7) isa location;

  $o8 isa company, has username "NorthStarLogisticsCorp.", has name "NorthStar Logistics Corp.", has bio "NorthStar Logistics Corp. delivers reliable, end-to-end supply chain solutions. With expertise in transportation, warehousing, and global shipping, we ensure your goods move swiftly and securely across borders. We keep your business on track with seamless logistics.", has profile-picture "med-a6245b598c944f98b3386c3e1af4787f", has is-active true, has is-visible true, has can-publish true, has tag "#Logistics", has tag "#SupplyChain", has tag "#GlobalShipping", has tag "#FreightSolutions", has tag "#Warehousing", has tag "#TransportationServices", has tag "#ShippingSolutions";
  (place: $santa-fe, located: $o8) isa location;

  $o9 isa company, has username "PinnacleVenturesLtd.", has name "Pinnacle Ventures Ltd.", has bio "Pinnacle Ventures Ltd. drives innovation by partnering with startups and established businesses to fuel growth. We provide venture capital, mentorship, and strategic guidance to help bold ideas turn into industry-changing enterprises. Turning visions into reality.", has profile-picture "med-c6c3744cc88e43b6a2276cbc31e9ca80", has is-active true, has is-visible true, has can-publish true, has tag "#VentureCapital", has tag "#StartupFunding", has tag "#BusinessGrowth", has tag "#Investment", has tag "#Entrepreneurship", has tag "#BusinessMentorship", has tag "#InnovationFunding";
  (place: $bristol, located: $o9) isa location;

  $o10 isa company, has username "BrightPathPharmaceuticals", has name "BrightPath Pharmaceuticals", has bio "BrightPath Pharmaceuticals is dedicated to advancing healthcare through research and innovation. Specializing in cutting-edge drug development, we are committed to creating life-changing medications that improve patient outcomes and enhance quality of life.", has profile-picture "med-9c30ceaa0f66432da19b58371c6a4b5e", has is-active true, has is-visible true, has can-publish true, has tag "#Pharmaceuticals", has tag "#DrugDevelopment", has tag "#HealthcareInnovation", has tag "#MedicalResearch", has tag "#PatientCare", has tag "#LifeSciences", has tag "#HealthSolutions";
  (place: $london, located: $o10) isa location;

  $o11 isa charity, has username "BrightHorizonsInitiative", has name "Bright Horizons Initiative", has bio "Bright Horizons Initiative is dedicated to providing educational resources and support to underserved communities. Our mission is to create opportunities for children and families through access to quality education and mentorship. Empowering the next generation with the tools to succeed and thrive.", has profile-picture "med-567e5862ef154673a1df3da79d44c93e", has is-active true, has is-visible true, has can-publish true, has tag "#EducationForAll", has tag "#CommunitySupport", has tag "#ChildDevelopment", has tag "#MentorshipPrograms", has tag "#EqualOpportunities", has tag "#YouthEmpowerment", has tag "#NonProfit";
  (place: $sevastopol, located: $o11) isa location;

  $o12 isa charity, has username "HeartwellReliefFund", has name "Heartwell Relief Fund", has bio "Heartwell Relief Fund focuses on providing emergency aid and long-term recovery support to communities affected by natural disasters. We work on the ground to deliver immediate relief and assist in rebuilding efforts, offering hope and resources to those in need. Compassion in action for disaster-stricken regions.", has profile-picture "med-9f3dd894b6af48b2aeba42d0f8303249", has is-active true, has is-visible true, has can-publish true, has tag "#DisasterRelief", has tag "#EmergencyAid", has tag "#HumanitarianSupport", has tag "#RebuildingLives", has tag "#CrisisResponse", has tag "#CommunityRecovery", has tag "#NonProfitOrganization";
  (place: $seattle, located: $o12) isa location;

  $o13 isa charity, has username "GreenStepsEnvironmentalTrust", has name "GreenSteps Environmental Trust", has bio "GreenSteps Environmental Trust is committed to protecting the planet through conservation, education, and sustainable initiatives. We work to reduce environmental impact and promote eco-friendly practices in communities and businesses. Together, we can take steps toward a greener future.", has profile-picture "med-f55e3aa2208a493e9960af85c9df7e44", has is-active true, has is-visible true, has can-publish true, has tag "#EnvironmentalConservation", has tag "#Sustainability", has tag "#EcoFriendly", has tag "#ClimateAction", has tag "#GreenInitiatives", has tag "#WildlifeProtection", has tag "#NonProfitEnvironmental";
  (place: $albuquerque, located: $o13) isa location;

  $o14 isa college, has username "SterlingHillsCollege", has name "Sterling Hills College", has bio "Sterling Hills College is a vibrant, community-focused institution offering a diverse range of academic programs and vocational training. Our mission is to provide accessible, high-quality education that prepares students for success in their chosen careers. A place where knowledge meets opportunity.", has profile-picture "med-beebb4eaeab9421b8b36b545cca1a034", has is-active true, has is-visible true, has can-publish true, has tag "#CommunityCollege", has tag "#CareerTraining", has tag "#HigherEducation", has tag "#AccessibleLearning", has tag "#StudentSuccess", has tag "#AcademicExcellence", has tag "#VocationalTraining";
  (place: $sevastopol, located: $o14) isa location;

  $o15 isa college, has username "NorthernCrestAcademy", has name "Northern Crest Academy", has bio "Northern Crest Academy is dedicated to fostering academic excellence and personal growth in a supportive, inclusive environment. We offer a well-rounded curriculum with a strong focus on critical thinking and leadership development. Building bright futures through innovation and education.", has profile-picture "med-feef71cbc91541139c45488d84dda9b9", has is-active true, has is-visible true, has can-publish true, has tag "#AcademyEducation", has tag "#StudentLeadership", has tag "#CriticalThinking", has tag "#PersonalGrowth", has tag "#InclusiveEducation", has tag "#InnovationInLearning", has tag "#FutureLeaders";
  (place: $nyc, located: $o15) isa location;

  $o16 isa university, has username "WestbridgeUniversity", has name "Westbridge University", has bio "Westbridge University is a prestigious institution known for its commitment to academic rigor and innovative research. We offer a wide array of undergraduate and graduate programs designed to challenge and inspire our students. At Westbridge, we shape the leaders of tomorrow through knowledge and discovery.", has profile-picture "med-71cff814645b47768838a14509c67417", has is-active true, has is-visible true, has can-publish true, has tag "#UniversityLife", has tag "#AcademicExcellence", has tag "#HigherEducation", has tag "#InnovativeResearch", has tag "#UndergraduatePrograms", has tag "#GraduatePrograms", has tag "#FutureLeaders";
  (place: $santa-fe, located: $o16) isa location;

  $o17 isa university, has username "OakwoodInstituteofTechnology", has name "Oakwood Institute of Technology", has bio "Oakwood Institute of Technology specializes in cutting-edge education in science, technology, engineering, and mathematics (STEM). Our goal is to equip students with the skills and knowledge necessary to excel in the tech-driven world. Bridging the gap between innovation and practical application.", has profile-picture "med-5b471c437499428cb0c32323c1b199c4", has is-active true, has is-visible true, has can-publish true, has tag "#STEMEducation", has tag "#TechInstitute", has tag "#Engineering", has tag "#Innovation", has tag "#CuttingEdgeTech", has tag "#STEMCareers", has tag "#PracticalLearning";
  (place: $san-francisco, located: $o17) isa location;

  $o18 isa university, has username "RiverfordUniversity", has name "Riverford University", has bio "Riverford University is a dynamic, forward-thinking university with a strong emphasis on interdisciplinary studies and global perspectives. We are dedicated to cultivating intellectual curiosity and fostering collaboration across diverse fields of study. Preparing students to make a meaningful impact on the world stage.", has profile-picture "med-ef2d9a38e6e448df8b6d9611f4dd05d5", has is-active true, has is-visible true, has can-publish true, has tag "#InterdisciplinaryStudies", has tag "#GlobalEducation", has tag "#UniversityLife", has tag "#HigherLearning", has tag "#ResearchAndInnovation", has tag "#CollaborativeLearning", has tag "#WorldImpact";
  (place: $los-angeles, located: $o18) isa location;
end;
# groups
insert
  $g1 isa group, has group-id "grp-06d2ed7ce6ac4d8a8160ff927c7550f2", has name "All-Star Sports Network", has bio "All-Star Sports Network is the ultimate community for athletes, sports fans, and fitness enthusiasts. Whether you’re into football, basketball, running, or any other sport, this is the place to share training tips, game highlights, and stay updated on the latest news. Join us to connect with others who live and breathe sports, and take your game to the next level!", has profile-picture "med-91bacf80aaa049968522dc4ef1dd50bf", has is-active true, has is-visible true, has page-visibility "public", has post-visibility "public", has tag "#SportsCommunity", has tag "#AthleteLife", has tag "#GameDay", has tag "#FitnessTips", has tag "#SportsTraining", has tag "#SportsFans", has tag "#TeamSpirit", has tag "#ActiveLifestyle";
  $g2 isa group, has group-id "grp-3acaaf82374a4cc9a0397e67926146de", has name "Gourmet Foodies Circle", has bio "Gourmet Foodies Circle is a vibrant community for food lovers, home cooks, and culinary adventurers. Whether you’re passionate about trying new recipes, exploring global cuisines, or sharing restaurant recommendations, this is the place to connect with fellow foodies. Join us to swap cooking tips, review dishes, and celebrate the love of great food!", has profile-picture "med-e27ac8e9d1c341bc86be643217ee0eb0", has is-active true, has is-visible true, has page-visibility "public", has post-visibility "public", has tag "#FoodLovers", has tag "#CulinaryAdventures", has tag "#HomeCooking", has tag "#GourmetRecipes", has tag "#FoodiesUnite", has tag "#GlobalCuisines", has tag "#RestaurantReviews", has tag "#CookingTips";
  $g3 isa group, has group-id "grp-809e2109c7864a38a09f1aede38690e7", has name "The Urban Explorers Collective", has bio "The Urban Explorers Collective is a community of adventurers passionate about exploring hidden corners of cities. From forgotten buildings to secret rooftops, we seek out the untold stories of urban landscapes. Join us to discover, document, and share the unseen sides of your city.", has profile-picture "med-81d1bf066b8c46f28611f583b2d10e3d", has is-active true, has is-visible true, has page-visibility "public", has post-visibility "public", has tag "#UrbanExploration", has tag "#CityAdventures", has tag "#HiddenGems", has tag "#UrbanExplorers", has tag "#Photography", has tag "#StreetCulture", has tag "#UrbanDiscoveries";
  $g4 isa group, has group-id "grp-254bf7ae1d0a4994b20b575d4e28e674", has name "IndexOne Initiative", has bio "IndexOne Initiative is a community of programmers who firmly believe that all indices should start at 1, not 0. We challenge the norms of traditional indexing with thoughtful discussions, coding practices, and advocacy for a more intuitive approach to programming. Join us in our mission to make the world of code a better place—one index at a time.", has profile-picture "med-6c0be55c90e649e1a44fc3a96d0c62c3", has is-active true, has is-visible true, has page-visibility "public", has post-visibility "public", has tag "#IndexOne", has tag "#ProgrammingDebate", has tag "#CodeIntuitively", has tag "#StartAtOne", has tag "#1BasedIndexing", has tag "#ProgrammingPhilosophy", has tag "#CodersUnite", has tag "#IndexOneRevolution";
  $g5 isa group, has group-id "grp-1ad1daaaef8d4ff095831feeec41e6f6", has name "Vintage Car Enthusiasts Society", has bio "The Vintage Car Enthusiasts Society is a group of classic car lovers who share a passion for restoring, collecting, and admiring vintage automobiles. Our members exchange tips on restoration, showcase their prized cars, and attend events to celebrate the history and beauty of classic vehicles.", has profile-picture "med-6a48054219654435901bb5fa6a677623", has is-active true, has is-visible true, has page-visibility "public", has post-visibility "public", has tag "#VintageCars", has tag "#ClassicCarRestoration", has tag "#CarEnthusiasts", has tag "#AutoCollectors", has tag "#ClassicVehicles", has tag "#CarShows", has tag "#VintageAutomobiles";
end;
