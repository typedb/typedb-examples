  $cmt_2_3 isa comment; $cmt_2_3 has comment-id "cmt-111868f86a4a4e0e989a95009f13d2fb"; $cmt_2_3 has comment-text "@ValerieChesser891 True that! I remember my first day was super stressful, but it gets better."; $cmt_2_3 has creation-timestamp 2023-07-16T15:30:00.000; $cmt_2_3 has is-visible true; $cmting_2_3 isa commenting, links (parent: $pc_cmt_e583847f852d4ee58061fd30d9073286, comment: $cmt_2_3, author: $pf_PatriciaShelman960); $cmt_2_3 has tag "@ValerieChesser891";
