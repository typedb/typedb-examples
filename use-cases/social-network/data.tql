  $cmt_1_166 isa comment; $cmt_1_166 has comment-id "cmt-51d670bd73f64b09b68712c085dc1819"; $cmt_1_166 has comment-text "That’s awesome! Archery looks so fun! How long did it take to get that shot?"; $cmt_1_166 has creation-timestamp 2023-08-15T13:00:00.000; $cmt_1_166 has is-visible true; $cmting_1_166 isa commenting, links (parent: $pp_pst_df6316b93f734143a4dcea5ab888cb65, comment: $cmt_1_166, author: $pf_RonaldFincham197);
