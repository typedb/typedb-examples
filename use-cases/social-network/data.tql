  $pp_pst_f5f5b0d2042e4feca0e63d0e8f8b36e4 isa post, has id "pst-f5f5b0d2042e4feca0e63d0e8f8b36e4";
  $pp_pst_fa9fcece50ed4af2a35f6be1f8b55fb5 isa post, has id "pst-fa9fcece50ed4af2a35f6be1f8b55fb5";
  $pp_pst_ffbdfd47dc7942f0933894b3854ca896 isa post, has id "pst-ffbdfd47dc7942f0933894b3854ca896";
insert
  $cmt_1_1 isa comment; $cmt_1_1 has comment-id "cmt-9aca0c4ad24e41049dd26234213124bd"; $cmt_1_1 has comment-text "Congrats @FrankieLorenz269! Hope everything goes well on your first day."; $cmt_1_1 has creation-timestamp 2023-07-16T15:10:00.000; $cmt_1_1 has is-visible true; $cmting_1_1 isa commenting, links (parent: $pp_pst_01275a6388da491ba1f6c8770212585b, comment: $cmt_1_1, author: $pf_PatriciaShelman960); $cmt_1_1 has tag "@FrankieLorenz269";
  $cmt_1_2 isa comment; $cmt_1_2 has comment-id "cmt-e583847f852d4ee58061fd30d9073286"; $cmt_1_2 has comment-text "Good luck @FrankieLorenz269! First days are tough, but you’ll be fine."; $cmt_1_2 has creation-timestamp 2023-07-16T15:20:00.000; $cmt_1_2 has is-visible true; $cmting_1_2 isa commenting, links (parent: $pp_pst_01275a6388da491ba1f6c8770212585b, comment: $cmt_1_2, author: $pf_ValerieChesser891); $cmt_1_2 has tag "@FrankieLorenz269";
  $cmt_1_3 isa comment; $cmt_1_3 has comment-id "cmt-61c61ae46a594b07ada678063a19607d"; $cmt_1_3 has comment-text "Awesome news @FrankieLorenz269! Let us know how it goes at the end of the day."; $cmt_1_3 has creation-timestamp 2023-07-16T16:05:00.000; $cmt_1_3 has is-visible true; $cmting_1_3 isa commenting, links (parent: $pp_pst_01275a6388da491ba1f6c8770212585b, comment: $cmt_1_3, author: $pf_JohnRugg309); $cmt_1_3 has tag "@FrankieLorenz269";
  $cmt_1_4 isa comment; $cmt_1_4 has comment-id "cmt-074f3be044f24133b45c88409da28338"; $cmt_1_4 has comment-text "I’ve heard mixed reviews. Some people say it’s amazing, but others are having issues with battery life. Maybe wait for a few software updates?"; $cmt_1_4 has creation-timestamp 2022-11-10T13:00:00.000; $cmt_1_4 has is-visible true; $cmting_1_4 isa commenting, links (parent: $pp_pst_0a8bc856c3ed49b7b9df727561994015, comment: $cmt_1_4, author: $pf_ValerieChesser891);
  $cmt_1_5 isa comment; $cmt_1_5 has comment-id "cmt-845c21e7988d4e4aa266a107a408001f"; $cmt_1_5 has comment-text "I’ve had it for a week now, and I love it! The camera is incredible, and I haven’t noticed any battery issues so far."; $cmt_1_5 has creation-timestamp 2022-11-10T13:20:00.000; $cmt_1_5 has is-visible true; $cmting_1_5 isa commenting, links (parent: $pp_pst_0a8bc856c3ed49b7b9df727561994015, comment: $cmt_1_5, author: $pf_MaryBrown547);
  $cmt_1_6 isa comment; $cmt_1_6 has comment-id "cmt-c5a918d19eed443ca4536074b13de531"; $cmt_1_6 has comment-text "I’m still using my phone from three years ago and it works just fine. Is the upgrade really necessary?"; $cmt_1_6 has creation-timestamp 2022-11-10T14:10:00.000; $cmt_1_6 has is-visible true; $cmting_1_6 isa commenting, links (parent: $pp_pst_0a8bc856c3ed49b7b9df727561994015, comment: $cmt_1_6, author: $pf_MichaelShah533);
  $cmt_1_7 isa comment; $cmt_1_7 has comment-id "cmt-e4ad24e2824d4e969fe253b079801aaa"; $cmt_1_7 has comment-text "Yes! I watched it last night. It’s amazing how far we’ve come in terms of technology and understanding the universe."; $cmt_1_7 has creation-timestamp 2021-03-22T11:00:00.000; $cmt_1_7 has is-visible true; $cmting_1_7 isa commenting, links (parent: $pp_pst_e93b4418b17041ed9b040be38f41d3e4, comment: $cmt_1_7, author: $pf_PatriciaShelman960);
  $cmt_1_8 isa comment; $cmt_1_8 has comment-id "cmt-d26d028dd1f14ee795e9718e816480fa"; $cmt_1_8 has comment-text "I haven’t seen it yet. Is it more focused on past missions or future exploration?"; $cmt_1_8 has creation-timestamp 2021-03-22T12:00:00.000; $cmt_1_8 has is-visible true; $cmting_1_8 isa commenting, links (parent: $pp_pst_e93b4418b17041ed9b040be38f41d3e4, comment: $cmt_1_8, author: $pf_DorothyGardner851);
  $cmt_1_9 isa comment; $cmt_1_9 has comment-id "cmt-b931a26d726e4017861f567969083bd6"; $cmt_1_9 has comment-text "I’ve been meaning to watch it. I’ve always been fascinated by space, but I’m curious about how accurate these documentaries are. Do they oversimplify things?"; $cmt_1_9 has creation-timestamp 2021-03-22T12:20:00.000; $cmt_1_9 has is-visible true; $cmting_1_9 isa commenting, links (parent: $pp_pst_e93b4418b17041ed9b040be38f41d3e4, comment: $cmt_1_9, author: $pf_SoilaMcafee389);
  $cmt_1_10 isa comment; $cmt_1_10 has comment-id "cmt-99755cb97c764592a73e3f3b5c27761d"; $cmt_1_10 has comment-text "I just finished 'The Silent Patient.' It’s a psychological thriller with a crazy twist at the end. Highly recommend it!"; $cmt_1_10 has creation-timestamp 2020-09-05T18:40:00.000; $cmt_1_10 has is-visible true; $cmting_1_10 isa commenting, links (parent: $pp_pst_4894d9fc70df47b9ba6f36fa241813ef, comment: $cmt_1_10, author: $pf_PatriciaShelman960);
  $cmt_1_11 isa comment; $cmt_1_11 has comment-id "cmt-166a1a98af3b4a9185bab545d4e26a5b"; $cmt_1_11 has comment-text "If you’re into fantasy, try 'Mistborn' by Brandon Sanderson. Great world-building and characters. I couldn’t put it down."; $cmt_1_11 has creation-timestamp 2020-09-05T19:10:00.000; $cmt_1_11 has is-visible true; $cmting_1_11 isa commenting, links (parent: $pp_pst_4894d9fc70df47b9ba6f36fa241813ef, comment: $cmt_1_11, author: $pf_NathanLopez643);
  $cmt_1_12 isa comment; $cmt_1_12 has comment-id "cmt-09642b3157c2447fa7b51ee70f1a6c44"; $cmt_1_12 has comment-text "I’m reading 'Sapiens' right now. It’s non-fiction and dives into the history of humankind. If you want something thought-provoking, this one’s for you."; $cmt_1_12 has creation-timestamp 2020-09-05T19:50:00.000; $cmt_1_12 has is-visible true; $cmting_1_12 isa commenting, links (parent: $pp_pst_4894d9fc70df47b9ba6f36fa241813ef, comment: $cmt_1_12, author: $pf_ValerieChesser891);
  $cmt_1_13 isa comment; $cmt_1_13 has comment-id "cmt-69560c0630084519ad83095163eaa005"; $cmt_1_13 has comment-text "If you want something lighter and fun, 'The Rosie Project' is a great rom-com with some quirky characters. A really enjoyable read."; $cmt_1_13 has creation-timestamp 2020-09-05T20:30:00.000; $cmt_1_13 has is-visible true; $cmting_1_13 isa commenting, links (parent: $pp_pst_4894d9fc70df47b9ba6f36fa241813ef, comment: $cmt_1_13, author: $pf_MaryBrown547);
  $cmt_1_14 isa comment; $cmt_1_14 has comment-id "cmt-53fb2ed1b9534807b00961c3855a7d8d"; $cmt_1_14 has comment-text "That’s exciting! My advice: pack light. You’ll thank yourself later, especially if you plan to move around a lot."; $cmt_1_14 has creation-timestamp 2023-02-14T09:45:00.000; $cmt_1_14 has is-visible true; $cmting_1_14 isa commenting, links (parent: $pp_pst_d46e34aaae9d47978284e0bee33e270a, comment: $cmt_1_14, author: $pf_MichaelShah533);
  $cmt_1_15 isa comment; $cmt_1_15 has comment-id "cmt-952b750d9830449d99efbb41b66b6b0b"; $cmt_1_15 has comment-text "Definitely bring copies of your important documents, like your passport. You never know what might happen."; $cmt_1_15 has creation-timestamp 2023-02-14T09:55:00.000; $cmt_1_15 has is-visible true; $cmting_1_15 isa commenting, links (parent: $pp_pst_d46e34aaae9d47978284e0bee33e270a, comment: $cmt_1_15, author: $pf_BarbaraCriswell869);
  $cmt_1_16 isa comment; $cmt_1_16 has comment-id "cmt-991ab513369f4284adc641cd921bc646"; $cmt_1_16 has comment-text "Make sure you learn some basic phrases in the local language. It goes a long way in showing respect, even if it’s just 'hello' and 'thank you.'"; $cmt_1_16 has creation-timestamp 2023-02-14T10:30:00.000; $cmt_1_16 has is-visible true; $cmting_1_16 isa commenting, links (parent: $pp_pst_d46e34aaae9d47978284e0bee33e270a, comment: $cmt_1_16, author: $pf_MaryBrown547);
  $cmt_1_17 isa comment; $cmt_1_17 has comment-id "cmt-5153f737d7f14ec29a9dadd2e7aad070"; $cmt_1_17 has comment-text "Don’t forget travel insurance. It might seem unnecessary, but it can save you a lot of hassle if something goes wrong."; $cmt_1_17 has creation-timestamp 2023-02-14T11:00:00.000; $cmt_1_17 has is-visible true; $cmting_1_17 isa commenting, links (parent: $pp_pst_d46e34aaae9d47978284e0bee33e270a, comment: $cmt_1_17, author: $pf_MeganHood510);
  $cmt_1_18 isa comment; $cmt_1_18 has comment-id "cmt-aedab7b5e2aa45a7895103edfd05a5f5"; $cmt_1_18 has comment-text "Start small! It’s easy to get overwhelmed if you plant too much at once. Focus on a few easy crops like tomatoes or lettuce."; $cmt_1_18 has creation-timestamp 2021-06-21T08:45:00.000; $cmt_1_18 has is-visible true; $cmting_1_18 isa commenting, links (parent: $pp_pst_a2521f50a54e4c8facb3077a6cef5e55, comment: $cmt_1_18, author: $pf_SarahGiven225);
  $cmt_1_19 isa comment; $cmt_1_19 has comment-id "cmt-d7de701d8eaf43239f65380029c836e0"; $cmt_1_19 has comment-text "Make sure you check your soil. You might need to add compost or fertilizer depending on where you live."; $cmt_1_19 has creation-timestamp 2021-06-21T09:10:00.000; $cmt_1_19 has is-visible true; $cmting_1_19 isa commenting, links (parent: $pp_pst_a2521f50a54e4c8facb3077a6cef5e55, comment: $cmt_1_19, author: $pf_CrystalMilazzo699);
  $cmt_1_20 isa comment; $cmt_1_20 has comment-id "cmt-113c183677f4431bbde9d47dd89331ac"; $cmt_1_20 has comment-text "Watering consistently is key, especially during the summer. Try to water in the morning to prevent diseases."; $cmt_1_20 has creation-timestamp 2021-06-21T09:50:00.000; $cmt_1_20 has is-visible true; $cmting_1_20 isa commenting, links (parent: $pp_pst_a2521f50a54e4c8facb3077a6cef5e55, comment: $cmt_1_20, author: $pf_RonaldFincham197);
  $cmt_1_21 isa comment; $cmt_1_21 has comment-id "cmt-efb80c63f42f438fa7e08e2fc06bad38"; $cmt_1_21 has comment-text "You should try growing herbs like basil or mint. They’re pretty easy and you can use them in cooking right away!"; $cmt_1_21 has creation-timestamp 2021-06-21T10:20:00.000; $cmt_1_21 has is-visible true; $cmting_1_21 isa commenting, links (parent: $pp_pst_a2521f50a54e4c8facb3077a6cef5e55, comment: $cmt_1_21, author: $pf_MaryBrown547);
  $cmt_1_22 isa comment; $cmt_1_22 has comment-id "cmt-dfb8770891d2425a95e19cb6698eecba"; $cmt_1_22 has comment-text "Start with simple recipes like cookies or banana bread. They’re forgiving and don’t require too much precision."; $cmt_1_22 has creation-timestamp 2020-12-05T14:45:00.000; $cmt_1_22 has is-visible true; $cmting_1_22 isa commenting, links (parent: $pp_pst_da98da57166a4fc4b513198c67f8ab57, comment: $cmt_1_22, author: $pf_AnthonyRansom097);
  $cmt_1_23 isa comment; $cmt_1_23 has comment-id "cmt-a49999cf87e54bbca2e9e671ab341860"; $cmt_1_23 has comment-text "Make sure to measure your ingredients properly, especially when it comes to flour. Too much or too little can really affect the outcome."; $cmt_1_23 has creation-timestamp 2020-12-05T15:10:00.000; $cmt_1_23 has is-visible true; $cmting_1_23 isa commenting, links (parent: $pp_pst_da98da57166a4fc4b513198c67f8ab57, comment: $cmt_1_23, author: $pf_MaryBrown547);
  $cmt_1_24 isa comment; $cmt_1_24 has comment-id "cmt-140a642e10e847f88986148f8b3e00e7"; $cmt_1_24 has comment-text "Don’t be afraid to experiment with flavors once you’re comfortable. Adding things like cinnamon or vanilla can make a huge difference."; $cmt_1_24 has creation-timestamp 2020-12-05T15:40:00.000; $cmt_1_24 has is-visible true; $cmting_1_24 isa commenting, links (parent: $pp_pst_da98da57166a4fc4b513198c67f8ab57, comment: $cmt_1_24, author: $pf_JaniceRich109);
  $cmt_1_25 isa comment; $cmt_1_25 has comment-id "cmt-6b5a174d34364eaa83ea038fc095e099"; $cmt_1_25 has comment-text "If you’re looking for something a bit more challenging, try making bread from scratch. It’s a lot of fun and super rewarding!"; $cmt_1_25 has creation-timestamp 2020-12-05T16:10:00.000; $cmt_1_25 has is-visible true; $cmting_1_25 isa commenting, links (parent: $pp_pst_da98da57166a4fc4b513198c67f8ab57, comment: $cmt_1_25, author: $pf_BarbaraCriswell869);
  $cmt_1_26 isa comment; $cmt_1_26 has comment-id "cmt-42260a44773b4350a743e0df5e15428a"; $cmt_1_26 has comment-text "Labradors are great for first-time owners! They’re friendly, easy to train, and good with families."; $cmt_1_26 has creation-timestamp 2023-08-15T16:35:00.000; $cmt_1_26 has is-visible true; $cmting_1_26 isa commenting, links (parent: $pp_pst_833cf90ff55546289d153fb4968051b7, comment: $cmt_1_26, author: $pf_SoilaMcafee389);
  $cmt_1_27 isa comment; $cmt_1_27 has comment-id "cmt-81be81f4bef844d7a251d74d61f9c408"; $cmt_1_27 has comment-text "I’d recommend a Golden Retriever. They’re similar to Labs but a little more laid-back. Great for first-time dog owners."; $cmt_1_27 has creation-timestamp 2023-08-15T17:10:00.000; $cmt_1_27 has is-visible true; $cmting_1_27 isa commenting, links (parent: $pp_pst_833cf90ff55546289d153fb4968051b7, comment: $cmt_1_27, author: $pf_JaniceRich109);
  $cmt_1_28 isa comment; $cmt_1_28 has comment-id "cmt-a07f7f4750c64a8ca7a0008c0b44361f"; $cmt_1_28 has comment-text "Don’t forget about adopting from a shelter! Mixed breeds can be fantastic, and you might find the perfect dog without worrying too much about breed specifics."; $cmt_1_28 has creation-timestamp 2023-08-15T17:50:00.000; $cmt_1_28 has is-visible true; $cmting_1_28 isa commenting, links (parent: $pp_pst_833cf90ff55546289d153fb4968051b7, comment: $cmt_1_28, author: $pf_AnthonyRansom097);
  $cmt_1_29 isa comment; $cmt_1_29 has comment-id "cmt-7abc9f0b86fe4dedbe38784bf489362c"; $cmt_1_29 has comment-text "Consider a smaller breed like a Beagle or a French Bulldog if space is a concern. They’re lower maintenance and can adapt to apartment living."; $cmt_1_29 has creation-timestamp 2023-08-15T18:20:00.000; $cmt_1_29 has is-visible true; $cmting_1_29 isa commenting, links (parent: $pp_pst_833cf90ff55546289d153fb4968051b7, comment: $cmt_1_29, author: $pf_ValerieChesser891);
  $cmt_1_30 isa comment; $cmt_1_30 has comment-id "cmt-3f7512c56e05424db49b93d51e709e19"; $cmt_1_30 has comment-text "Start with some YouTube videos! There are a lot of beginner yoga routines out there. I recommend Yoga with Adriene; she has a whole series for beginners."; $cmt_1_30 has creation-timestamp 2022-05-10T14:30:00.000; $cmt_1_30 has is-visible true; $cmting_1_30 isa commenting, links (parent: $pp_pst_07f79ee0e2994b48a449213ac2fab184, comment: $cmt_1_30, author: $pf_VilmaToft456);
  $cmt_1_31 isa comment; $cmt_1_31 has comment-id "cmt-4aa83cd6580448819d8cca3b62614790"; $cmt_1_31 has comment-text "Try to focus on your breathing as much as the poses. Yoga is as much about mindfulness as it is about flexibility."; $cmt_1_31 has creation-timestamp 2022-05-10T14:50:00.000; $cmt_1_31 has is-visible true; $cmting_1_31 isa commenting, links (parent: $pp_pst_07f79ee0e2994b48a449213ac2fab184, comment: $cmt_1_31, author: $pf_NancyJohnson650);
  $cmt_1_32 isa comment; $cmt_1_32 has comment-id "cmt-83f0ba7756b8402a8f424ffa8abb572c"; $cmt_1_32 has comment-text "You might want to invest in a good yoga mat. It makes a big difference in comfort, especially for longer sessions."; $cmt_1_32 has creation-timestamp 2022-05-10T15:30:00.000; $cmt_1_32 has is-visible true; $cmting_1_32 isa commenting, links (parent: $pp_pst_07f79ee0e2994b48a449213ac2fab184, comment: $cmt_1_32, author: $pf_MaryBrown547);
  $cmt_1_33 isa comment; $cmt_1_33 has comment-id "cmt-233e383454e24ea68202faf9dcebef56"; $cmt_1_33 has comment-text "Make sure to stretch before and after each session. Even though yoga is all about stretching, it’s good to loosen up beforehand to avoid injury."; $cmt_1_33 has creation-timestamp 2022-05-10T16:10:00.000; $cmt_1_33 has is-visible true; $cmting_1_33 isa commenting, links (parent: $pp_pst_07f79ee0e2994b48a449213ac2fab184, comment: $cmt_1_33, author: $pf_FrankieLorenz269);
  $cmt_1_34 isa comment; $cmt_1_34 has comment-id "cmt-08df6b197c3a4037a0d5c16e961139cf"; $cmt_1_34 has comment-text "Congrats! That’s amazing! My biggest advice is to listen to your team. Make sure everyone feels heard, and you’ll build trust fast."; $cmt_1_34 has creation-timestamp 2023-11-20T09:15:00.000; $cmt_1_34 has is-visible true; $cmting_1_34 isa commenting, links (parent: $pp_pst_ffbdfd47dc7942f0933894b3854ca896, comment: $cmt_1_34, author: $pf_JeffLeon452);
  $cmt_1_35 isa comment; $cmt_1_35 has comment-id "cmt-d61a43f28ecb497198c8ece658ea0417"; $cmt_1_35 has comment-text "Congratulations! Don’t be afraid to delegate tasks. It’s easy to feel like you need to do everything, but trusting your team is key."; $cmt_1_35 has creation-timestamp 2023-11-20T09:30:00.000; $cmt_1_35 has is-visible true; $cmting_1_35 isa commenting, links (parent: $pp_pst_ffbdfd47dc7942f0933894b3854ca896, comment: $cmt_1_35, author: $pf_JaniceRich109);
  $cmt_1_36 isa comment; $cmt_1_36 has comment-id "cmt-3aeb5bc0f63d407ca9d21bf8b1954990"; $cmt_1_36 has comment-text "Congrats! One tip: be clear with your expectations, but also stay approachable. It helps create a balance between leadership and teamwork."; $cmt_1_36 has creation-timestamp 2023-11-20T09:45:00.000; $cmt_1_36 has is-visible true; $cmting_1_36 isa commenting, links (parent: $pp_pst_ffbdfd47dc7942f0933894b3854ca896, comment: $cmt_1_36, author: $pf_SoilaMcafee389);
  $cmt_1_37 isa comment; $cmt_1_37 has comment-id "cmt-28702bb1593149b4b06146ffbecba4c8"; $cmt_1_37 has comment-text "That’s awesome! My advice: set regular check-ins with your team. It keeps things on track and helps everyone stay aligned on goals."; $cmt_1_37 has creation-timestamp 2023-11-20T10:00:00.000; $cmt_1_37 has is-visible true; $cmting_1_37 isa commenting, links (parent: $pp_pst_ffbdfd47dc7942f0933894b3854ca896, comment: $cmt_1_37, author: $pf_SarahGiven225);
  $cmt_1_38 isa comment; $cmt_1_38 has comment-id "cmt-8c1a612bfff94f34b94d9109593985b5"; $cmt_1_38 has comment-text "Congratulations! Remember, it’s okay to make mistakes and learn as you go. No one expects you to be perfect right away."; $cmt_1_38 has creation-timestamp 2023-11-20T10:15:00.000; $cmt_1_38 has is-visible true; $cmting_1_38 isa commenting, links (parent: $pp_pst_ffbdfd47dc7942f0933894b3854ca896, comment: $cmt_1_38, author: $pf_DouglasBrown163);
  $cmt_1_39 isa comment; $cmt_1_39 has comment-id "cmt-c833b07eb4d54ffc9f4a518a4ef0ba9b"; $cmt_1_39 has comment-text "Congrats! Fixer-uppers are a lot of work, but it’s so rewarding when you start seeing the transformation. What’s the first project you’re tackling?"; $cmt_1_39 has creation-timestamp 2023-12-01T16:15:00.000; $cmt_1_39 has is-visible true; $cmting_1_39 isa commenting, links (parent: $pp_pst_53fd2516d1bf4abaa908923b1551f819, comment: $cmt_1_39, author: $pf_MaryBrown547);
  $cmt_1_40 isa comment; $cmt_1_40 has comment-id "cmt-cda840fd4adb4798839d60ba9c993735"; $cmt_1_40 has comment-text "Congratulations! That’s so exciting. Are you planning to do most of the work yourselves or hire pros for the big stuff?"; $cmt_1_40 has creation-timestamp 2023-12-01T16:30:00.000; $cmt_1_40 has is-visible true; $cmting_1_40 isa commenting, links (parent: $pp_pst_53fd2516d1bf4abaa908923b1551f819, comment: $cmt_1_40, author: $pf_JohnRugg309);
  $cmt_1_41 isa comment; $cmt_1_41 has comment-id "cmt-8dff06d283404ed5b38f8437faa2cbad"; $cmt_1_41 has comment-text "That’s amazing! There’s something special about making a house truly yours. Are you planning any big changes, like knocking down walls?"; $cmt_1_41 has creation-timestamp 2023-12-01T16:45:00.000; $cmt_1_41 has is-visible true; $cmting_1_41 isa commenting, links (parent: $pp_pst_53fd2516d1bf4abaa908923b1551f819, comment: $cmt_1_41, author: $pf_JaniceRich109);
  $cmt_1_42 isa comment; $cmt_1_42 has comment-id "cmt-d4dc2301882a492580b2db0c6a2465cf"; $cmt_1_42 has comment-text "Congrats on the new home! Do you have any design themes in mind? Modern, rustic, or something else?"; $cmt_1_42 has creation-timestamp 2023-12-01T17:00:00.000; $cmt_1_42 has is-visible true; $cmting_1_42 isa commenting, links (parent: $pp_pst_53fd2516d1bf4abaa908923b1551f819, comment: $cmt_1_42, author: $pf_WilliamRing568);
  $cmt_1_43 isa comment; $cmt_1_43 has comment-id "cmt-52fa3935ff284550b6847398fabbc6b6"; $cmt_1_43 has comment-text "So happy for you! I’m sure it’ll be a lot of work, but the satisfaction of seeing it all come together will be worth it. Any outdoor projects planned too?"; $cmt_1_43 has creation-timestamp 2023-12-01T17:20:00.000; $cmt_1_43 has is-visible true; $cmting_1_43 isa commenting, links (parent: $pp_pst_53fd2516d1bf4abaa908923b1551f819, comment: $cmt_1_43, author: $pf_JosephineHenry396);
  $cmt_1_44 isa comment; $cmt_1_44 has comment-id "cmt-f9d0a163def1474a93801f2544f06c4e"; $cmt_1_44 has comment-text "Congrats! That’s a huge achievement. How are you feeling now? Totally exhausted or still running on adrenaline?"; $cmt_1_44 has creation-timestamp 2023-11-28T14:15:00.000; $cmt_1_44 has is-visible true; $cmting_1_44 isa commenting, links (parent: $pp_pst_d87d3afca3704e8a821ac45bd5e32aef, comment: $cmt_1_44, author: $pf_JaniceRich109);
  $cmt_1_45 isa comment; $cmt_1_45 has comment-id "cmt-49954cf1faaf400ca74b3d208c3fa29f"; $cmt_1_45 has comment-text "Amazing! Finishing a marathon is no joke. How was the race atmosphere? Was the crowd cheering you on?"; $cmt_1_45 has creation-timestamp 2023-11-28T14:30:00.000; $cmt_1_45 has is-visible true; $cmting_1_45 isa commenting, links (parent: $pp_pst_d87d3afca3704e8a821ac45bd5e32aef, comment: $cmt_1_45, author: $pf_FrankieLorenz269);
  $cmt_1_46 isa comment; $cmt_1_46 has comment-id "cmt-84403b37b13b4d4ea368f7d2d9732b86"; $cmt_1_46 has comment-text "That’s awesome! Did you hit a wall at any point, or did the energy just carry you through?"; $cmt_1_46 has creation-timestamp 2023-11-28T14:45:00.000; $cmt_1_46 has is-visible true; $cmting_1_46 isa commenting, links (parent: $pp_pst_d87d3afca3704e8a821ac45bd5e32aef, comment: $cmt_1_46, author: $pf_RonaldFincham197);
  $cmt_1_47 isa comment; $cmt_1_47 has comment-id "cmt-47e77e2b6b294a13a37c3644c9345ce7"; $cmt_1_47 has comment-text "Wow, huge congrats! What was your go-to song during the run to keep you going?"; $cmt_1_47 has creation-timestamp 2023-11-28T15:00:00.000; $cmt_1_47 has is-visible true; $cmting_1_47 isa commenting, links (parent: $pp_pst_d87d3afca3704e8a821ac45bd5e32aef, comment: $cmt_1_47, author: $pf_DorothyGardner851);
  $cmt_1_48 isa comment; $cmt_1_48 has comment-id "cmt-88653e42cefe43eca9184b9f501049e2"; $cmt_1_48 has comment-text "Finishing a marathon is a huge accomplishment! Do you think you’ll run another one, or is this a one-time thing?"; $cmt_1_48 has creation-timestamp 2023-11-28T15:15:00.000; $cmt_1_48 has is-visible true; $cmting_1_48 isa commenting, links (parent: $pp_pst_d87d3afca3704e8a821ac45bd5e32aef, comment: $cmt_1_48, author: $pf_VilmaToft456);
  $cmt_1_49 isa comment; $cmt_1_49 has comment-id "cmt-14c30b503d0d4ad087d5e121623a35ae"; $cmt_1_49 has comment-text "Aww, congrats! Luna is such a cute name. How’s she adjusting so far?"; $cmt_1_49 has creation-timestamp 2023-12-10T10:15:00.000; $cmt_1_49 has is-visible true; $cmting_1_49 isa commenting, links (parent: $pp_pst_7a31a27cced44d7cb4ca01423b239fd8, comment: $cmt_1_49, author: $pf_MichaelFincher442);
  $cmt_1_50 isa comment; $cmt_1_50 has comment-id "cmt-700b1433f5d64476a0f12d46e775f27e"; $cmt_1_50 has comment-text "Congrats on adopting! Rescues are the best. What breed is Luna?"; $cmt_1_50 has creation-timestamp 2023-12-10T10:30:00.000; $cmt_1_50 has is-visible true; $cmting_1_50 isa commenting, links (parent: $pp_pst_7a31a27cced44d7cb4ca01423b239fd8, comment: $cmt_1_50, author: $pf_MeganHood510);
  $cmt_1_51 isa comment; $cmt_1_51 has comment-id "cmt-86ff76d11fe34b56a9f5a74186861f29"; $cmt_1_51 has comment-text "That’s awesome! Can’t wait to see all the adventures you two go on together. Any plans for her first big outing?"; $cmt_1_51 has creation-timestamp 2023-12-10T10:45:00.000; $cmt_1_51 has is-visible true; $cmting_1_51 isa commenting, links (parent: $pp_pst_7a31a27cced44d7cb4ca01423b239fd8, comment: $cmt_1_51, author: $pf_BobbieMoreno546);
  $cmt_1_52 isa comment; $cmt_1_52 has comment-id "cmt-b287c4407881407dae771359677abeb7"; $cmt_1_52 has comment-text "Luna is lucky to have found you! Do you think she’ll be a cuddler, or is she more independent?"; $cmt_1_52 has creation-timestamp 2023-12-10T11:00:00.000; $cmt_1_52 has is-visible true; $cmting_1_52 isa commenting, links (parent: $pp_pst_7a31a27cced44d7cb4ca01423b239fd8, comment: $cmt_1_52, author: $pf_EstherCarter759);
  $cmt_1_53 isa comment; $cmt_1_53 has comment-id "cmt-86343347daa6426aa30d04fdb58c1e9f"; $cmt_1_53 has comment-text "This is so heartwarming! Rescuing is such a great thing to do. Does she have any favorite toys yet?"; $cmt_1_53 has creation-timestamp 2023-12-10T11:15:00.000; $cmt_1_53 has is-visible true; $cmting_1_53 isa commenting, links (parent: $pp_pst_7a31a27cced44d7cb4ca01423b239fd8, comment: $cmt_1_53, author: $pf_JosephineHenry396);
  $cmt_1_54 isa comment; $cmt_1_54 has comment-id "cmt-6ad8c64db8c54e789214f218dd3b8d93"; $cmt_1_54 has comment-text "I actually loved it! I think the chaos of the plot was intentional—it mirrors the character’s journey through confusion and self-discovery."; $cmt_1_54 has creation-timestamp 2021-09-30T19:20:00.000; $cmt_1_54 has is-visible true; $cmting_1_54 isa commenting, links (parent: $pp_pst_3b8ddd5b2e664ecb86f9f4e68b4eb003, comment: $cmt_1_54, author: $pf_MaryBrown547);
  $cmt_1_55 isa comment; $cmt_1_55 has comment-id "cmt-8f5a5adec21d4eadbe4c13622826ef27"; $cmt_1_55 has comment-text "I agree with @VilmaToft456. The action scenes were great, but the character development felt rushed. They tried to pack too much into one movie."; $cmt_1_55 has creation-timestamp 2021-09-30T19:50:00.000; $cmt_1_55 has is-visible true; $cmting_1_55 isa commenting, links (parent: $pp_pst_3b8ddd5b2e664ecb86f9f4e68b4eb003, comment: $cmt_1_55, author: $pf_SarahGiven225); $cmt_1_55 has tag "@VilmaToft456";
  $cmt_1_56 isa comment; $cmt_1_56 has comment-id "cmt-4ca49e01c6214f7fbcd4fb198625dcb0"; $cmt_1_56 has comment-text "The special effects were insane, though! That fight scene at the end had me on the edge of my seat."; $cmt_1_56 has creation-timestamp 2021-09-30T20:10:00.000; $cmt_1_56 has is-visible true; $cmting_1_56 isa commenting, links (parent: $pp_pst_3b8ddd5b2e664ecb86f9f4e68b4eb003, comment: $cmt_1_56, author: $pf_NancyJohnson650);
  $cmt_1_57 isa comment; $cmt_1_57 has comment-id "cmt-b8d1353905624912bdf2b5a1b57a5c03"; $cmt_1_57 has comment-text "I’m just tired of superhero movies in general. They all follow the same formula—good guy vs bad guy with some big explosions."; $cmt_1_57 has creation-timestamp 2021-09-30T20:35:00.000; $cmt_1_57 has is-visible true; $cmting_1_57 isa commenting, links (parent: $pp_pst_3b8ddd5b2e664ecb86f9f4e68b4eb003, comment: $cmt_1_57, author: $pf_VilmaToft456);
  $cmt_1_58 isa comment; $cmt_1_58 has comment-id "cmt-1a608f0d7e4142ad86b0915a8880f9fd"; $cmt_1_58 has comment-text "Oh man, for me it was definitely 'Cosmic Explorers'! I used to watch it every Saturday morning. That theme song still lives rent-free in my head."; $cmt_1_58 has creation-timestamp 2022-12-01T21:25:00.000; $cmt_1_58 has is-visible true; $cmting_1_58 isa commenting, links (parent: $pp_pst_6282c33d366546a5a34da412816a5ea8, comment: $cmt_1_58, author: $pf_PatriciaShelman960);
  $cmt_1_59 isa comment; $cmt_1_59 has comment-id "cmt-bf33551df629453582b33be214ed05bd"; $cmt_1_59 has comment-text "Mine was 'Jungle Warriors.' I was obsessed with the animal characters, especially the cheetah who could run super fast."; $cmt_1_59 has creation-timestamp 2022-12-01T22:00:00.000; $cmt_1_59 has is-visible true; $cmting_1_59 isa commenting, links (parent: $pp_pst_6282c33d366546a5a34da412816a5ea8, comment: $cmt_1_59, author: $pf_SoilaMcafee389);
  $cmt_1_60 isa comment; $cmt_1_60 has comment-id "cmt-fc145cfe469a4289ac91c01e734c5192"; $cmt_1_60 has comment-text "No one’s mentioned 'Robot Squadron'? I loved that show! It was all about teamwork, and the gadgets they used were so fun."; $cmt_1_60 has creation-timestamp 2022-12-01T22:20:00.000; $cmt_1_60 has is-visible true; $cmting_1_60 isa commenting, links (parent: $pp_pst_6282c33d366546a5a34da412816a5ea8, comment: $cmt_1_60, author: $pf_MichaelShah533);
  $cmt_1_61 isa comment; $cmt_1_61 has comment-id "cmt-139e5ca2b9e74780821cf26265739938"; $cmt_1_61 has comment-text "I have to go with 'Mystery Kids.' It had such a cool mix of mystery and humor. I still remember trying to solve the cases before the characters did!"; $cmt_1_61 has creation-timestamp 2022-12-01T22:45:00.000; $cmt_1_61 has is-visible true; $cmting_1_61 isa commenting, links (parent: $pp_pst_6282c33d366546a5a34da412816a5ea8, comment: $cmt_1_61, author: $pf_MeganHood510);
  $cmt_1_62 isa comment; $cmt_1_62 has comment-id "cmt-c2eaf172e5a1424387281f15b5cbb690"; $cmt_1_62 has comment-text "Teleportation is a good one, but I’d pick the ability to control time. You could pause, rewind, or fast forward through awkward situations."; $cmt_1_62 has creation-timestamp 2023-06-10T17:30:00.000; $cmt_1_62 has is-visible true; $cmting_1_62 isa commenting, links (parent: $pp_pst_735b3a803fbd4eedb23dc8f5b17078ee, comment: $cmt_1_62, author: $pf_MeganHood510);
  $cmt_1_63 isa comment; $cmt_1_63 has comment-id "cmt-037432634a0649aa827acd0de15093b0"; $cmt_1_63 has comment-text "I’d go with invisibility. Sometimes it’d be nice to just disappear for a while and have some peace and quiet."; $cmt_1_63 has creation-timestamp 2023-06-10T17:50:00.000; $cmt_1_63 has is-visible true; $cmting_1_63 isa commenting, links (parent: $pp_pst_735b3a803fbd4eedb23dc8f5b17078ee, comment: $cmt_1_63, author: $pf_EstherCarter759);
  $cmt_1_64 isa comment; $cmt_1_64 has comment-id "cmt-f6b4160bd46647729df5672b5ba48aa0"; $cmt_1_64 has comment-text "Flying, no question. Who wouldn’t want to soar through the skies? Plus, you could skip traffic completely."; $cmt_1_64 has creation-timestamp 2023-06-10T18:10:00.000; $cmt_1_64 has is-visible true; $cmting_1_64 isa commenting, links (parent: $pp_pst_735b3a803fbd4eedb23dc8f5b17078ee, comment: $cmt_1_64, author: $pf_JohnRugg309);
  $cmt_1_65 isa comment; $cmt_1_65 has comment-id "cmt-d55f0e0eef6b4029bbef627fce91e0c9"; $cmt_1_65 has comment-text "I’d choose the ability to speak and understand any language instantly. You could travel anywhere and connect with anyone in their native language."; $cmt_1_65 has creation-timestamp 2023-06-10T18:50:00.000; $cmt_1_65 has is-visible true; $cmting_1_65 isa commenting, links (parent: $pp_pst_735b3a803fbd4eedb23dc8f5b17078ee, comment: $cmt_1_65, author: $pf_ValerieChesser891);
  $cmt_1_66 isa comment; $cmt_1_66 has comment-id "cmt-59581c9454f54df7a9bf79f4b3739067"; $cmt_1_66 has comment-text "Congratulations! That’s amazing news! How did you propose?"; $cmt_1_66 has creation-timestamp 2023-12-15T08:45:00.000; $cmt_1_66 has is-visible true; $cmting_1_66 isa commenting, links (parent: $pp_pst_cf085288f0044e328bc01de3d197b561, comment: $cmt_1_66, author: $pf_DorothyGardner851);
  $cmt_1_67 isa comment; $cmt_1_67 has comment-id "cmt-b20ed71966b9421b942917266557338d"; $cmt_1_67 has comment-text "So happy for you both! Did you have the ring picked out for a while, or was it a recent decision?"; $cmt_1_67 has creation-timestamp 2023-12-15T09:10:00.000; $cmt_1_67 has is-visible true; $cmting_1_67 isa commenting, links (parent: $pp_pst_cf085288f0044e328bc01de3d197b561, comment: $cmt_1_67, author: $pf_AnnaThomas446);
  $cmt_1_68 isa comment; $cmt_1_68 has comment-id "cmt-d7e239089090424481d44db0d09bf39c"; $cmt_1_68 has comment-text "That’s incredible! Any immediate wedding plans, or are you just soaking in the engagement for now?"; $cmt_1_68 has creation-timestamp 2023-12-15T09:30:00.000; $cmt_1_68 has is-visible true; $cmting_1_68 isa commenting, links (parent: $pp_pst_cf085288f0044e328bc01de3d197b561, comment: $cmt_1_68, author: $pf_VilmaToft456);
  $cmt_1_69 isa comment; $cmt_1_69 has comment-id "cmt-8278e1e52adb4a6783add75843e1592e"; $cmt_1_69 has comment-text "Congrats! Do you have a date in mind for the wedding, or is it too soon to say?"; $cmt_1_69 has creation-timestamp 2023-12-15T09:45:00.000; $cmt_1_69 has is-visible true; $cmting_1_69 isa commenting, links (parent: $pp_pst_cf085288f0044e328bc01de3d197b561, comment: $cmt_1_69, author: $pf_BarbaraCriswell869);
  $cmt_1_70 isa comment; $cmt_1_70 has comment-id "cmt-c710fab3881f43bda669d6b6c1afb76b"; $cmt_1_70 has comment-text "Big congratulations to you both! Did you tell your family and friends yet, or are you keeping it a secret for a little while?"; $cmt_1_70 has creation-timestamp 2023-12-15T10:00:00.000; $cmt_1_70 has is-visible true; $cmting_1_70 isa commenting, links (parent: $pp_pst_cf085288f0044e328bc01de3d197b561, comment: $cmt_1_70, author: $pf_FrankieLorenz269);
  $cmt_1_71 isa comment; $cmt_1_71 has comment-id "cmt-31bf3b36bac144b58a19e5a80d5a2ad3"; $cmt_1_71 has comment-text "Whoa, that looks amazing! Is it as fast as it looks?"; $cmt_1_71 has creation-timestamp 2023-07-20T15:45:00.000; $cmt_1_71 has is-visible true; $cmting_1_71 isa commenting, links (parent: $pp_pst_86d77094a6894303a807092d74ca0c56, comment: $cmt_1_71, author: $pf_DorothyGardner851);
  $cmt_1_72 isa comment; $cmt_1_72 has comment-id "cmt-98e16bc0338549c784ade7b7119b0fb4"; $cmt_1_72 has comment-text "That car is a beauty! What’s the first road trip you’re planning?"; $cmt_1_72 has creation-timestamp 2023-07-20T16:10:00.000; $cmt_1_72 has is-visible true; $cmting_1_72 isa commenting, links (parent: $pp_pst_86d77094a6894303a807092d74ca0c56, comment: $cmt_1_72, author: $pf_ValerieChesser891);
  $cmt_1_73 isa comment; $cmt_1_73 has comment-id "cmt-e55b88fff0864962b771f867dfa2e52b"; $cmt_1_73 has comment-text "That’s a slick ride! What model is it? I’ve been thinking about upgrading my car too."; $cmt_1_73 has creation-timestamp 2023-07-20T16:40:00.000; $cmt_1_73 has is-visible true; $cmting_1_73 isa commenting, links (parent: $pp_pst_86d77094a6894303a807092d74ca0c56, comment: $cmt_1_73, author: $pf_MichaelFincher442);
  $cmt_1_74 isa comment; $cmt_1_74 has comment-id "cmt-9c017e5d5c414fb5a94a29d3f73c3dce"; $cmt_1_74 has comment-text "Now that’s a car worthy of some serious weekend adventures. I’m picturing you zipping down the highway with the top down!"; $cmt_1_74 has creation-timestamp 2023-07-20T17:00:00.000; $cmt_1_74 has is-visible true; $cmting_1_74 isa commenting, links (parent: $pp_pst_86d77094a6894303a807092d74ca0c56, comment: $cmt_1_74, author: $pf_JeffLeon452);
  $cmt_1_75 isa comment; $cmt_1_75 has comment-id "cmt-054961d6043843d4a81b3fe3fda48455"; $cmt_1_75 has comment-text "Okay, I’m officially jealous! You better give me a ride next time we hang out."; $cmt_1_75 has creation-timestamp 2023-07-20T17:20:00.000; $cmt_1_75 has is-visible true; $cmting_1_75 isa commenting, links (parent: $pp_pst_86d77094a6894303a807092d74ca0c56, comment: $cmt_1_75, author: $pf_VilmaToft456);
  $cmt_1_76 isa comment; $cmt_1_76 has comment-id "cmt-c4a0c1cd06544465b311d9c41d86fd12"; $cmt_1_76 has comment-text "Wow, that looks like paradise! Where are you?"; $cmt_1_76 has creation-timestamp 2023-03-10T14:20:00.000; $cmt_1_76 has is-visible true; $cmting_1_76 isa commenting, links (parent: $pp_pst_c8359b916e934faf9502e1d5167ad089, comment: $cmt_1_76, author: $pf_VilmaToft456);
  $cmt_1_77 isa comment; $cmt_1_77 has comment-id "cmt-32620328624a4daeabbcf1f6dedff24b"; $cmt_1_77 has comment-text "I could use some of that sunshine right now! Looks amazing!"; $cmt_1_77 has creation-timestamp 2023-03-10T14:40:00.000; $cmt_1_77 has is-visible true; $cmting_1_77 isa commenting, links (parent: $pp_pst_c8359b916e934faf9502e1d5167ad089, comment: $cmt_1_77, author: $pf_NancyJohnson650);
  $cmt_1_78 isa comment; $cmt_1_78 has comment-id "cmt-9c9afcff26b14865a878e8767f0df2ca"; $cmt_1_78 has comment-text "That water looks crystal clear. How’s the snorkeling?"; $cmt_1_78 has creation-timestamp 2023-03-10T15:00:00.000; $cmt_1_78 has is-visible true; $cmting_1_78 isa commenting, links (parent: $pp_pst_c8359b916e934faf9502e1d5167ad089, comment: $cmt_1_78, author: $pf_DorothyGardner851);
  $cmt_1_79 isa comment; $cmt_1_79 has comment-id "cmt-dc7843b3e91945aab0c99beaa0a1f43f"; $cmt_1_79 has comment-text "Living the dream! Hope you’re soaking up all that relaxation."; $cmt_1_79 has creation-timestamp 2023-03-10T15:25:00.000; $cmt_1_79 has is-visible true; $cmting_1_79 isa commenting, links (parent: $pp_pst_c8359b916e934faf9502e1d5167ad089, comment: $cmt_1_79, author: $pf_MaryBrown547);
  $cmt_1_80 isa comment; $cmt_1_80 has comment-id "cmt-0806989a9abf4e69a5bcd7ed6fa68010"; $cmt_1_80 has comment-text "Please tell me there’s a tropical drink in your hand right now."; $cmt_1_80 has creation-timestamp 2023-03-10T15:45:00.000; $cmt_1_80 has is-visible true; $cmting_1_80 isa commenting, links (parent: $pp_pst_c8359b916e934faf9502e1d5167ad089, comment: $cmt_1_80, author: $pf_JeffLeon452);
