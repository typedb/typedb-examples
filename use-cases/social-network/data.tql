# places: Americas hierarchy
insert
  $americas isa region, has place-id "plc-americas", has name "Americas";

  $northern-america isa region, has place-id "plc-americas/northern-america", has name "North America";
  (parent-region: $americas, child-region: $northern-america) isa region-location;

  $us isa country, has place-id "plc-americas/northern-america/united-states", has name "United States", has language "English";
  (region: $northern-america, country: $us) isa country-location;

  $california isa state, has place-id "plc-americas/northern-america/united-states/california", has name "California"; (country: $us, state: $california) isa state-location;
  $texas isa state, has place-id "plc-americas/northern-america/united-states/texas", has name "Texas"; (country: $us, state: $texas) isa state-location;
  $new-york isa state, has place-id "plc-americas/northern-america/united-states/new-york", has name "New York"; (country: $us, state: $new-york) isa state-location;
  $new-jersey isa state, has place-id "plc-americas/northern-america/united-states/new-jersey", has name "New Jersey"; (country: $us, state: $new-jersey) isa state-location;
  $washington isa state, has place-id "plc-americas/northern-america/united-states/washington", has name "Washington"; (country: $us, state: $washington) isa state-location;
  $massachusetts isa state, has place-id "plc-americas/northern-america/united-states/massachusetts", has name "Massachusetts"; (country: $us, state: $massachusetts) isa state-location;
  $new-mexico isa state, has place-id "plc-americas/northern-america/united-states/new-mexico", has name "New Mexico"; (country: $us, state: $new-mexico) isa state-location;
  $missouri isa state, has place-id "plc-americas/northern-america/united-states/missouri", has name "Missouri"; (country: $us, state: $missouri) isa state-location;

  $sacramento isa city, has place-id "plc-americas/northern-america/united-states/california/sacramento", has name "Sacramento"; (parent: $california, city: $sacramento) isa city-location;
  $los-angeles isa city, has place-id "plc-americas/northern-america/united-states/california/los-angeles", has name "Los Angeles"; (parent: $california, city: $los-angeles) isa city-location;
  $san-francisco isa city, has place-id "plc-americas/northern-america/united-states/california/san-francisco", has name "San Francisco"; (parent: $california, city: $san-francisco) isa city-location;
  $sevastopol isa city, has place-id "plc-americas/northern-america/united-states/california/sevastopol", has name "Sevastopol"; (parent: $california, city: $sevastopol) isa city-location;
  $austin isa city, has place-id "plc-americas/northern-america/united-states/texas/austin", has name "Austin"; (parent: $texas, city: $austin) isa city-location;
  $albany isa city, has place-id "plc-americas/northern-america/united-states/new-york/albany", has name "Albany"; (parent: $new-york, city: $albany) isa city-location;
  $nyc isa city, has place-id "plc-americas/northern-america/united-states/new-york/new-york-city", has name "New York City"; (parent: $new-york, city: $nyc) isa city-location;
  $trenton isa city, has place-id "plc-americas/northern-america/united-states/new-jersey/trenton", has name "Trenton"; (parent: $new-jersey, city: $trenton) isa city-location;
  $newark isa city, has place-id "plc-americas/northern-america/united-states/new-jersey/newark", has name "Newark"; (parent: $new-jersey, city: $newark) isa city-location;
  $seattle isa city, has place-id "plc-americas/northern-america/united-states/washington/seattle", has name "Seattle"; (parent: $washington, city: $seattle) isa city-location;
  $boston isa city, has place-id "plc-americas/northern-america/united-states/massachusetts/boston", has name "Boston"; (parent: $massachusetts, city: $boston) isa city-location;
  $santa-fe isa city, has place-id "plc-americas/northern-america/united-states/new-mexico/santa-fe", has name "Santa Fe"; (parent: $new-mexico, city: $santa-fe) isa city-location;
  $albuquerque isa city, has place-id "plc-americas/northern-america/united-states/new-mexico/albuquerque", has name "Albuquerque"; (parent: $new-mexico, city: $albuquerque) isa city-location;
  $kansas-city isa city, has place-id "plc-americas/northern-america/united-states/missouri/kansas-city", has name "Kansas City"; (parent: $missouri, city: $kansas-city) isa city-location;

  $canada isa country, has place-id "plc-americas/northern-america/canada", has name "Canada", has language "English", has language "French";
  (region: $northern-america, country: $canada) isa country-location;

  $ontario isa state, has place-id "plc-americas/northern-america/canada/ontario", has name "Ontario"; (country: $canada, state: $ontario) isa state-location;
  $quebec isa state, has place-id "plc-americas/northern-america/canada/quebec", has name "Quebec"; (country: $canada, state: $quebec) isa state-location;

  $toronto isa city, has place-id "plc-americas/northern-america/canada/ontario/toronto", has name "Toronto"; (parent: $ontario, city: $toronto) isa city-location;
  $quebec-city isa city, has place-id "plc-americas/northern-america/canada/quebec/quebec-city", has name "Quebec City"; (parent: $quebec, city: $quebec-city) isa city-location;
  $montreal isa city, has place-id "plc-americas/northern-america/canada/quebec/montreal", has name "Montreal"; (parent: $quebec, city: $montreal) isa city-location;
end;

# places: Europe hierarchy
insert
  $europe isa region, has place-id "plc-europe", has name "Europe";

  $northern-europe isa region, has place-id "plc-europe/northern-europe", has name "Northern Europe";
  (parent-region: $europe, child-region: $northern-europe) isa region-location;

  $uk isa country, has place-id "plc-europe/northern-europe/united-kingdom", has name "United Kingdom", has language "English";
  (region: $northern-europe, country: $uk) isa country-location;

  $london isa city, has place-id "plc-europe/northern-europe/united-kingdom/london", has name "London"; (parent: $uk, city: $london) isa city-location;
  $bristol isa city, has place-id "plc-europe/northern-europe/united-kingdom/bristol", has name "Bristol"; (parent: $uk, city: $bristol) isa city-location;
  $liverpool isa city, has place-id "plc-europe/northern-europe/united-kingdom/liverpool", has name "Liverpool"; (parent: $uk, city: $liverpool) isa city-location;
end;

