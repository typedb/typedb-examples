insert
  $cmt_3_1 isa comment; $cmt_3_1 has comment-id "cmt-3bfb255eed0d4418ad58bce989745cd7"; $cmt_3_1 has comment-text "Exactly, the first week is the hardest."; $cmt_3_1 has creation-timestamp 2023-07-16T16:10:00.000; $cmt_3_1 has is-visible true; $cmting_3_1 isa commenting, links (parent: $pc_cmt_111868f86a4a4e0e989a95009f13d2fb, comment: $cmt_3_1, author: $pf_ValerieChesser891);
  $cmt_3_2 isa comment; $cmt_3_2 has comment-id "cmt-062d7f7a45da41f39a7e256db6ffe12c"; $cmt_3_2 has comment-text "It’s not too bad, to be honest. I haven’t had any issues with brightness even in sunlight."; $cmt_3_2 has creation-timestamp 2022-11-10T13:50:00.000; $cmt_3_2 has is-visible true; $cmting_3_2 isa commenting, links (parent: $pc_cmt_1a6f0c9af1f7490f80709bd41790a6b7, comment: $cmt_3_2, author: $pf_MaryBrown547);
  $cmt_3_3 isa comment; $cmt_3_3 has comment-id "cmt-51cd2c07a8f74b61b9d2b2de92bba701"; $cmt_3_3 has comment-text "@AnthonyRansom097 I say if your current phone still works well, maybe hold off. But if you’re really excited about the new features, why not treat yourself?"; $cmt_3_3 has creation-timestamp 2022-11-10T14:45:00.000; $cmt_3_3 has is-visible true; $cmting_3_3 isa commenting, links (parent: $pc_cmt_3503c56e61004dbda2ca9fe8a8aa7d13, comment: $cmt_3_3, author: $pf_ValerieChesser891); $cmt_3_3 has tag "@AnthonyRansom097";
  $cmt_3_4 isa comment; $cmt_3_4 has comment-id "cmt-6a8d3e8420fe452b96fe23018c3af69e"; $cmt_3_4 has comment-text "Right? The precision and planning required are just mind-blowing. I can’t imagine the pressure the scientists and engineers are under."; $cmt_3_4 has creation-timestamp 2021-03-22T11:30:00.000; $cmt_3_4 has is-visible true; $cmting_3_4 isa commenting, links (parent: $pc_cmt_74747f6f2dbd46e5b844c2ac729bd820, comment: $cmt_3_4, author: $pf_PatriciaShelman960);
  $cmt_3_5 isa comment; $cmt_3_5 has comment-id "cmt-ef617cacc6744244bb056d0259de5319"; $cmt_3_5 has comment-text "Sounds great! I’ll watch it tonight then."; $cmt_3_5 has creation-timestamp 2021-03-22T12:30:00.000; $cmt_3_5 has is-visible true; $cmting_3_5 isa commenting, links (parent: $pc_cmt_3f9bbcfc742c4905bbcab3eadcff697d, comment: $cmt_3_5, author: $pf_DorothyGardner851);
  $cmt_3_6 isa comment; $cmt_3_6 has comment-id "cmt-f239fbb01f6c4ec1ac546740a182e35f"; $cmt_3_6 has comment-text "@FrankieLorenz269 Exactly! The way the magic is tied to metal is so unique. @VilmaToft456, if you like fantasy, it’s a must-read."; $cmt_3_6 has creation-timestamp 2020-09-05T19:35:00.000; $cmt_3_6 has is-visible true; $cmting_3_6 isa commenting, links (parent: $pc_cmt_848edc98eec94a678cc672fc3006ff85, comment: $cmt_3_6, author: $pf_NathanLopez643); $cmt_3_6 has tag "@VilmaToft456"; $cmt_3_6 has tag "@FrankieLorenz269";
  $cmt_3_7 isa comment; $cmt_3_7 has comment-id "cmt-77f63854e6684b6e8408143f290d07e4"; $cmt_3_7 has comment-text "It’s definitely detailed, but not overwhelming. The way it’s written is really engaging. It covers a lot, but it’s not a tough read."; $cmt_3_7 has creation-timestamp 2020-09-05T20:15:00.000; $cmt_3_7 has is-visible true; $cmting_3_7 isa commenting, links (parent: $pc_cmt_ce1f40819f2d4db89ebaa89f559de204, comment: $cmt_3_7, author: $pf_ValerieChesser891);
  $cmt_3_8 isa comment; $cmt_3_8 has comment-id "cmt-a9c7ae92e61b4dc6be525e4f9e203161"; $cmt_3_8 has comment-text "Yes, that’s a great idea @PatriciaShelman960. Having digital copies can be a lifesaver."; $cmt_3_8 has creation-timestamp 2023-02-14T10:25:00.000; $cmt_3_8 has is-visible true; $cmting_3_8 isa commenting, links (parent: $pc_cmt_b050eb01a22f4818a6f332446f1d5baf, comment: $cmt_3_8, author: $pf_BarbaraCriswell869); $cmt_3_8 has tag "@PatriciaShelman960";
  $cmt_3_9 isa comment; $cmt_3_9 has comment-id "cmt-3e2b665322584df38ff0952a0b2591c4"; $cmt_3_9 has comment-text "Definitely, @AnthonyRansom097. Even for short trips, unexpected things can happen. It gives you peace of mind."; $cmt_3_9 has creation-timestamp 2023-02-14T11:30:00.000; $cmt_3_9 has is-visible true; $cmting_3_9 isa commenting, links (parent: $pc_cmt_0021b632324647d9bb2966398e4a295d, comment: $cmt_3_9, author: $pf_MeganHood510); $cmt_3_9 has tag "@AnthonyRansom097";
  $cmt_3_10 isa comment; $cmt_3_10 has comment-id "cmt-51497435a9c9424ebd723837705bacc2"; $cmt_3_10 has comment-text "You can get a soil test kit from most gardening stores. It’ll tell you if you need to adjust the pH or add nutrients."; $cmt_3_10 has creation-timestamp 2021-06-21T09:40:00.000; $cmt_3_10 has is-visible true; $cmting_3_10 isa commenting, links (parent: $pc_cmt_640ca20c702a4b67b7ae77585b45cf5a, comment: $cmt_3_10, author: $pf_CrystalMilazzo699);
  $cmt_3_11 isa comment; $cmt_3_11 has comment-id "cmt-fefd320bf5ef4a99810f5ddfa2251838"; $cmt_3_11 has comment-text "I just use a basic one from a recipe site. Add some chocolate chips or walnuts to make it extra delicious!"; $cmt_3_11 has creation-timestamp 2020-12-05T15:15:00.000; $cmt_3_11 has is-visible true; $cmting_3_11 isa commenting, links (parent: $pc_cmt_35e1392e8a744ec5a951743eca6cb87c, comment: $cmt_3_11, author: $pf_AnthonyRansom097);
  $cmt_3_12 isa comment; $cmt_3_12 has comment-id "cmt-38330558fb2343e796a2c379e0c6a8a7"; $cmt_3_12 has comment-text "Not too bad! They shed a bit, but regular brushing helps. They don’t need a lot of fancy grooming like some other breeds."; $cmt_3_12 has creation-timestamp 2023-08-15T17:00:00.000; $cmt_3_12 has is-visible true; $cmting_3_12 isa commenting, links (parent: $pc_cmt_4748f7ea72784d7597f0bfcf1c351dc9, comment: $cmt_3_12, author: $pf_SoilaMcafee389);
  $cmt_3_13 isa comment; $cmt_3_13 has comment-id "cmt-16c7354aef8244d6838dc8b1971964f8"; $cmt_3_13 has comment-text "Yeah, @MichaelShah533! They’re just big sweethearts. Plus, they’re pretty easy to train, which is a huge bonus."; $cmt_3_13 has creation-timestamp 2023-08-15T17:40:00.000; $cmt_3_13 has is-visible true; $cmting_3_13 isa commenting, links (parent: $pc_cmt_d2fb05ca3a724b9f96fb5c72ed6a1bfc, comment: $cmt_3_13, author: $pf_JaniceRich109); $cmt_3_13 has tag "@MichaelShah533";
  $cmt_3_14 isa comment; $cmt_3_14 has comment-id "cmt-8aae0c3ad31244e0bebbe60d3085ee6d"; $cmt_3_14 has comment-text "It gets easier with time. Just remember to go slow and don’t be too hard on yourself if your mind wanders."; $cmt_3_14 has creation-timestamp 2022-05-10T15:20:00.000; $cmt_3_14 has is-visible true; $cmting_3_14 isa commenting, links (parent: $pc_cmt_a31cc5d2cd9646a19dbdc6ff5fad7a0d, comment: $cmt_3_14, author: $pf_NancyJohnson650);
  $cmt_3_15 isa comment; $cmt_3_15 has comment-id "cmt-a31ca36b059e4b2e91cae1937ed61f4e"; $cmt_3_15 has comment-text "Manduka makes some of the best mats, but they’re a bit pricey. If you want something more budget-friendly, try Gaiam. Both are great for beginners."; $cmt_3_15 has creation-timestamp 2022-05-10T16:00:00.000; $cmt_3_15 has is-visible true; $cmting_3_15 isa commenting, links (parent: $pc_cmt_e875176629534a13839279358d5f52c0, comment: $cmt_3_15, author: $pf_MaryBrown547);
  $cmt_3_16 isa comment; $cmt_3_16 has comment-id "cmt-3f79dd31beb748d6ab021118ae63ad3a"; $cmt_3_16 has comment-text "@MaryBrown547 That’s fair. I’m hoping the next one expands on those arcs more. Still, this one felt like it was just trying to do too much at once."; $cmt_3_16 has creation-timestamp 2021-09-30T20:25:00.000; $cmt_3_16 has is-visible true; $cmting_3_16 isa commenting, links (parent: $pc_cmt_94d7f681d5514e14a18d99ce20fa5cd3, comment: $cmt_3_16, author: $pf_SarahGiven225); $cmt_3_16 has tag "@MaryBrown547";
