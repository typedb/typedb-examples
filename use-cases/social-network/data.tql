  $post49 isa live-video-post; $post49 has post-id "pst-1da11d7aa2814ecdb084486f52268c27"; $post49 has post-text "Live from my #artstudio! I’m working on a new #painting today—come hang out while I add some details. Any color suggestions? #artlife #creativity"; $post49 has creation-timestamp 2023-12-05T15:00:00.000; $post49 has language "English"; $post49 has is-visible true; $post49 has post-visibility "default"; $posting49 isa posting, links (page: $pg_LauraHarrison601, post: $post49, author: $pf_LauraHarrison601); $post49 has tag "#artstudio"; $post49 has tag "#artlife"; $post49 has tag "#painting"; $post49 has tag "#creativity"; $post49 has post-video "med-01fe2e706aa046f7a607dc9d55bdbbf6";
  $post50 isa live-video-post; $post50 has post-id "pst-8616ba88d2964670b35fda3eed38505b"; $post50 has post-text "Live from the #gym! I’m trying to beat my personal record for #deadlifts today. Tune in for some #fitnessmotivation! Any advice before I go for it? #workout #goals"; $post50 has creation-timestamp 2023-12-10T14:30:00.000; $post50 has language "English"; $post50 has is-visible true; $post50 has post-visibility "default"; $posting50 isa posting, links (page: $pg_grp_06d2ed7ce6ac4d8a8160ff927c7550f2, post: $post50, author: $pf_FrankieLorenz269); $post50 has tag "#goals"; $post50 has tag "#gym"; $post50 has tag "#workout"; $post50 has tag "#fitnessmotivation"; $post50 has tag "#deadlifts"; $loc50 isa location, links (place: $pl_plc_ab0c1681c8f843d093290a4cb5d32b16, located: $post50); $post50 has post-video "med-a881692c8bf74e12a0305e2d74319877";
  $post51 isa text-post; $post51 has post-id "pst-6b35da2c04464ea78abf5c57c5795b58"; $post51 has post-text "I’ve been working on a project that uses a 1-based index for #array manipulation, and let me tell you, the readability is just so much better. I can’t believe the world has stuck with 0-based indices for this long! #programming #codinglife #developer"; $post51 has creation-timestamp 2023-12-18T10:00:00.000; $post51 has language "English"; $post51 has is-visible true; $post51 has post-visibility "default"; $posting51 isa posting, links (page: $pg_grp_254bf7ae1d0a4994b20b575d4e28e674, post: $post51, author: $pf_MeganHood510); $post51 has tag "#array"; $post51 has tag "#codinglife"; $post51 has tag "#developer"; $post51 has tag "#programming";
  $post52 isa text-post; $post52 has post-id "pst-2d26904840134e33a77b20adfefed218"; $post52 has post-text "I’ve been thinking: If #spreadsheets like #Excel can default to 1-based indexing for rows and columns, why can’t #programminglanguages follow suit? It’s clearly more intuitive for most people! #techthoughts #coding"; $post52 has creation-timestamp 2023-12-20T09:30:00.000; $post52 has language "English"; $post52 has is-visible true; $post52 has post-visibility "default"; $posting52 isa posting, links (page: $pg_grp_254bf7ae1d0a4994b20b575d4e28e674, post: $post52, author: $pf_MichaelFincher442); $post52 has tag "#Excel"; $post52 has tag "#coding"; $post52 has tag "#techthoughts"; $post52 has tag "#spreadsheets"; $post52 has tag "#programminglanguages";
  $post53 isa text-post; $post53 has post-id "pst-964ede98ce624939af5d5c6294028d9a"; $post53 has post-text "I was refactoring some old #code today and realized just how much cleaner 1-based indexing would make some of these loops. It’s wild that we’ve normalized 0-based, but 1-based would make logic flow so much easier. #devlife #refactoring #codingtips"; $post53 has creation-timestamp 2023-12-22T13:00:00.000; $post53 has language "English"; $post53 has is-visible true; $post53 has post-visibility "default"; $posting53 isa posting, links (page: $pg_grp_254bf7ae1d0a4994b20b575d4e28e674, post: $post53, author: $pf_MeganHood510); $post53 has tag "#code"; $post53 has tag "#devlife"; $post53 has tag "#codingtips"; $post53 has tag "#refactoring";
end;
