  $cmt_3_21 isa comment; $cmt_3_21 has comment-id "cmt-e5540022450247f894a1396ce9abfb0d"; $cmt_3_21 has comment-text "@JaniceRich109 Totally! It adds the perfect pop of color."; $cmt_3_21 has creation-timestamp 2022-10-05T18:55:00.000; $cmt_3_21 has is-visible true; $cmting_3_21 isa commenting, links (parent: $pc_cmt_9be574017b33441eba2225d77c6d8ae1, comment: $cmt_3_21, author: $pf_JosephineHenry396); $cmt_3_21 has tag "@JaniceRich109";
