  $cmt_3_23 isa comment; $cmt_3_23 has comment-id "cmt-06ec9ad0e2cb4f40bb38a089fa4abdec"; $cmt_3_23 has comment-text "@BarbaraCriswell869 That’s impressive! I’ve been meaning to try making my own starter, but it seems tricky."; $cmt_3_23 has creation-timestamp 2023-05-15T14:40:00.000; $cmt_3_23 has is-visible true; $cmting_3_23 isa commenting, links (parent: $pc_cmt_c8a86e3a62934980a8795e631f742e70, comment: $cmt_3_23, author: $pf_MaryBrown547); $cmt_3_23 has tag "@BarbaraCriswell869";
  $cmt_3_24 isa comment; $cmt_3_24 has comment-id "cmt-dcbcd86ea2e84f7a9d6af484024d65de"; $cmt_3_24 has comment-text "@JaniceRich109 8 miles? Wow, that’s impressive! I bet the view at the top was worth it though."; $cmt_3_24 has creation-timestamp 2023-09-12T10:45:00.000; $cmt_3_24 has is-visible true; $cmting_3_24 isa commenting, links (parent: $pc_cmt_af44eaeb6734462fb62da54040b1f64d, comment: $cmt_3_24, author: $pf_MaryBrown547); $cmt_3_24 has tag "@JaniceRich109";
  $cmt_3_25 isa comment; $cmt_3_25 has comment-id "cmt-924dbea9ab614040a1abfa8b5fde5164"; $cmt_3_25 has comment-text "@MeganHood510 Yeah, they do need a lot of time, but the bond is so worth it. If you have the time, go for it!"; $cmt_3_25 has creation-timestamp 2023-09-30T11:15:00.000; $cmt_3_25 has is-visible true; $cmting_3_25 isa commenting, links (parent: $pc_cmt_3e2598d632ca4ebe98cd5da373cc3524, comment: $cmt_3_25, author: $pf_FrankieLorenz269); $cmt_3_25 has tag "@MeganHood510";
  $cmt_3_26 isa comment; $cmt_3_26 has comment-id "cmt-5462a18d1b6d4ce981364fc51a6ed97f"; $cmt_3_26 has comment-text "@MeganHood510 Not really! Just make sure they have food, water, and a clean litter box, and they’re happy. Super easy compared to dogs."; $cmt_3_26 has creation-timestamp 2023-09-30T11:50:00.000; $cmt_3_26 has is-visible true; $cmting_3_26 isa commenting, links (parent: $pc_cmt_03cd7bab667b44c9b3213530f0022e2e, comment: $cmt_3_26, author: $pf_BobbieMoreno546); $cmt_3_26 has tag "@MeganHood510";
  $cmt_3_27 isa comment; $cmt_3_27 has comment-id "cmt-8b75471e1a344ed597afa026e389adef"; $cmt_3_27 has comment-text "@MeganHood510 Some birds do, especially the more social ones. You’d need to spend time with them or maybe even get a second bird to keep them company."; $cmt_3_27 has creation-timestamp 2023-09-30T12:30:00.000; $cmt_3_27 has is-visible true; $cmting_3_27 isa commenting, links (parent: $pc_cmt_4d1df659c73641668042e02f1d732251, comment: $cmt_3_27, author: $pf_AnthonySpilis492); $cmt_3_27 has tag "@MeganHood510";
  $cmt_3_28 isa comment; $cmt_3_28 has comment-id "cmt-2a630fd171cf439daa1fff41af1b7013"; $cmt_3_28 has comment-text "@MeganHood510 Not too much, but you’ll need to clean the tank regularly and check the water quality. Once you get a routine, it’s pretty easy."; $cmt_3_28 has creation-timestamp 2023-09-30T13:15:00.000; $cmt_3_28 has is-visible true; $cmting_3_28 isa commenting, links (parent: $pc_cmt_1c7bc6c8d62f4e8cabca09663eef04eb, comment: $cmt_3_28, author: $pf_EstherCarter759); $cmt_3_28 has tag "@MeganHood510";
  $cmt_3_29 isa comment; $cmt_3_29 has comment-id "cmt-b3f4f5acf1064bce89d33c479f34cc10"; $cmt_3_29 has comment-text "@CrystalMilazzo699 Don’t worry about that! It’s all about having fun and experimenting. You don’t need to be a pro to enjoy it."; $cmt_3_29 has creation-timestamp 2023-11-01T12:45:00.000; $cmt_3_29 has is-visible true; $cmting_3_29 isa commenting, links (parent: $pc_cmt_796999735f4f49e185f1fc0aa486998f, comment: $cmt_3_29, author: $pf_JeffLeon452); $cmt_3_29 has tag "@CrystalMilazzo699";
