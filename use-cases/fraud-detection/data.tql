# Generated from the Kaggle credit-card fraud dataset (data.csv) plus the four
# sample banks. Bank assignment is deterministic (round-robin over cardholders)
# so the dataset and example-query results are reproducible.


insert
  $bank0 isa Bank, has name "ABC", has company_type "Bank";
  $bank0_coord isa Geo_coordinate, has latitude 30.5, has longitude -90.3;
  geolocate (coordinates: $bank0_coord, transacting_party: $bank0);
  $bank1 isa Bank, has name "MNO", has company_type "Bank";
  $bank1_coord isa Geo_coordinate, has latitude 33.986391, has longitude -81.200714;
  geolocate (coordinates: $bank1_coord, transacting_party: $bank1);
  $bank2 isa Bank, has name "QRS", has company_type "Bank";
  $bank2_coord isa Geo_coordinate, has latitude 43.7, has longitude -88.2;
  geolocate (coordinates: $bank2_coord, transacting_party: $bank2);
  $bank3 isa Bank, has name "XYZ", has company_type "Bank";
  $bank3_coord isa Geo_coordinate, has latitude 40.98, has longitude -90.4;
  geolocate (coordinates: $bank3_coord, transacting_party: $bank3);
end;

match
  $bank isa Bank, has name "ABC";
insert
  $coord isa Geo_coordinate, has latitude 33.9659, has longitude -80.9355;
  $addr isa Address, has street "351 Darlene Green", has city "Columbia", has state "SC", has zip 29209;
  $person isa Person, has first_name "Jeff", has last_name "Elliott", has gender "M", has job "Mechanical engineer", has date_of_birth 1968-03-19T00:00:00;
  locate (address: $addr, coordinates: $coord, transacting_party: $person);
  $card isa Card, has card_number 2291163933867244;
  bank_account (owner: $person, attached_card: $card, attached_bank: $bank);
end;

